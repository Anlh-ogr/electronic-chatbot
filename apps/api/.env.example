
# ===========================
# FastAPI runtime
# ===========================
APP_NAME=Elpis
ENV=dev
HOST=0.0.0.0
PORT=8000

# ===========================
# Database (PostgreSQL async)
# ===========================
DATABASE_URL=postgresql+asyncpg://chatbot_user1:1@localhost:5432/chatbot_db

# ===========================
# KiCad files storage
# Chỉ cần lưu tới root, không cần trỏ tới thư mục con cụ thể
# ===========================
KICAD_PROJECTS_DIR=D:\Work\thesis\kicad-projects


# ===========================
# KiCad symbols library (version 8.0.9)
# Trỏ tới thư mục chứa các file .kicad_sym
# ===========================
KICAD_SYMBOLS_DIR=apps/api/resources/kicad/symbols/version

# ===========================
# Chế độ xử lý mặc định: air (nhanh) | pro (sâu)
# ===========================
DEFAULT_MODE=air
ELECTRONICS_DOMAIN_ONLY=true

# ===========================
# Gemini AI (Google Generative AI)
# ===========================
GEMINI_API_KEY=

# ===========================
# Groq API (OpenAI-compatible)
# ===========================
GROQ_API_KEY=

# ── AIR mode — Groq chain (ROUTER, EXTRACTION): maverick → scout → 8b ──
GROQ_AIR_MODEL_1=meta-llama/llama-4-maverick-17b-128e-instruct
GROQ_AIR_MODEL_2=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_AIR_MODEL_3=llama-3.1-8b-instant

# ── AIR mode — Gemini chain (REASONING, PRESENTATION): 27b → 12b → flash-lite ──
GEMINI_AIR_MODEL_1=google/gemma-3-27b-it
GEMINI_AIR_MODEL_2=google/gemma-3-12b-it
GEMINI_AIR_MODEL_3=gemini-2.5-flash-lite

# ── PRO mode — Groq chain (EXTRACTION): gpt-oss-120b → 70b → kimi-k2 ──
GROQ_PRO_MODEL_1=openai/gpt-oss-120b
GROQ_PRO_MODEL_2=llama-3.3-70b-versatile
GROQ_PRO_MODEL_3=moonshotai/kimi-k2-instruct-0905

# ── PRO mode — Gemini chain (REASONING, PRESENTATION): flash-lite → 3-flash → 2.5-flash ──
GEMINI_PRO_MODEL_1=gemini-3.1-flash-lite
GEMINI_PRO_MODEL_2=gemini-3-flash
GEMINI_PRO_MODEL_3=gemini-2.5-flash