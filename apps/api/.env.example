
# ===========================
# FastAPI runtime
# ===========================
APP_NAME=Elpis
ENV=dev
HOST=0.0.0.0
PORT=8000

# ===========================
# Database (PostgreSQL async)
# ===========================
DATABASE_URL=postgresql+asyncpg://chatbot_user1:1@localhost:5432/chatbot_db

# ===========================
# KiCad files storage
# Chỉ cần lưu tới root, không cần trỏ tới thư mục con cụ thể
# ===========================
KICAD_PROJECTS_DIR=D:\Work\thesis\kicad-projects


# ===========================
# KiCad symbols library (version 8.0.9)
# Trỏ tới thư mục chứa các file .kicad_sym
# ===========================
KICAD_SYMBOLS_DIR=apps/api/resources/kicad/symbols/version

# ===========================
# Chế độ xử lý mặc định: air (nhanh) | pro (sâu)
# ===========================
DEFAULT_MODE=air
ELECTRONICS_DOMAIN_ONLY=true

# ===========================
# Google Cloud - Vertex AI
# ===========================
Google_Cloud_API_Key=Google_Cloud_API_KEY
Google_Cloud_Project_ID=Google_Cloud_Project_ID
Google_Cloud_Default_Mode=Air

# ==================== DEMO PHASE – MODEL ====================
Air:
Google_Cloud_Fast_Model=gemini-2.5-flash-lite   # demo cơ bản
Pro:
Google_Cloud_Think_Model=gemini-2.5-flash       # demo cơ bản
Google_Cloud_Pro_Model=gemini-2.0-flash-001     # demo cơ bản
Google_Cloud_Ultra_Model=gemini-flash-latest    # demo cơ bản

# ==================== PRODUCTION PHASE – CHÍNH THỨC ====================
# Air:
# Google_Cloud_Fast_Model=gemini-3.1-flash-lite-preview

# Pro:
# Google_Cloud_Think_Model=gemini-3.1-pro-preview
# Google_Cloud_Pro_Model=gemini-2.5-pro
# Google_Cloud_Ultra_Model=gemini-3.1-pro-preview