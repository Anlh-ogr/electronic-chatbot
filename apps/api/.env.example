
# ===========================
# FastAPI runtime
# ===========================
APP_NAME=Elpis
ENV=dev
HOST=0.0.0.0
PORT=8000

# ===========================
# Database (PostgreSQL async)
# ===========================
DATABASE_URL=postgresql+asyncpg://chatbot_user1:1@localhost:5432/chatbot_db

# ===========================
# KiCad files storage
# Chỉ cần lưu tới root, không cần trỏ tới thư mục con cụ thể
# ===========================
KICAD_PROJECTS_DIR=D:\Work\thesis\kicad-projects


# ===========================
# KiCad symbols library (version 8.0.9)
# Trỏ tới thư mục chứa các file .kicad_sym
# ===========================
KICAD_SYMBOLS_DIR=apps/api/resources/kicad/symbols/version

# ===========================
# Chế độ xử lý mặc định: air (nhanh) | pro (sâu)
# ===========================
DEFAULT_MODE=air
ELECTRONICS_DOMAIN_ONLY=true

# ===========================
# Google Cloud - Vertex AI
# ===========================
# Vertex AI dùng Application Default Credentials (ADC), không dùng API key AIza...
# Máy cá nhân: gcloud auth application-default login
# Server/Cloud: gán Service Account quyền roles/aiplatform.user (Vertex AI User)
Google_Cloud_API_Key=
Google_Cloud_Project_ID=project-2bdf5ad0-a50b-4dd6-95d
Google_Cloud_Default_Mode=Air
LLM_JSON_SCHEMA_MAX_RETRIES=4

# Stable family (Gemini 2.5)
Google_Cloud_Default_Location=us-central1

# Preview family (Gemini 3.1)
Google_Cloud_Preview_Location=global

# Mode: Fast
Google_Cloud_Fast_Model=gemini-2.5-flash
Google_Cloud_Fast_Location=us-central1
Google_Cloud_Fast_Timeout_Sec=25
Google_Cloud_Fast_Max_Tokens=8192

# Mode: Think
Google_Cloud_Think_Model=gemini-3.1-flash-lite-preview
Google_Cloud_Think_Location=global
Google_Cloud_Think_Timeout_Sec=40
Google_Cloud_Think_Max_Tokens=12288

# Mode: Pro
Google_Cloud_Pro_Model=gemini-2.5-pro
Google_Cloud_Pro_Location=us-central1
Google_Cloud_Pro_Timeout_Sec=45
Google_Cloud_Pro_Max_Tokens=16384

# Mode: Ultra
Google_Cloud_Ultra_Model=gemini-3.1-pro-preview-customtools
Google_Cloud_Ultra_Location=global
Google_Cloud_Ultra_Timeout_Sec=60
Google_Cloud_Ultra_Max_Tokens=24576