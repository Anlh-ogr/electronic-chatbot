{
  "$schema": "https://electronic-chatbot.local/schema/block-library.schema.json",
  "version": "v4.0.0",
  "description": "Thư viện block chức năng chuẩn cho Circuit Grammar. Mỗi block mô tả 1 khối chức năng độc lập có thể ghép với các block khác.",
  "blocks": {
    "ce_block": {
      "name": "Common Emitter Amplifier Block",
      "description": "Tầng khuếch đại BJT mắc emitter chung. Đảo pha 180°, gain áp trung bình-cao.",
      "device_type": "bjt",
      "input_ports": ["IN_BASE"],
      "output_ports": ["OUT_COLLECTOR"],
      "supply_ports": ["VCC", "GND"],
      "bias_ports": ["BIAS"],
      "gain_formula": "-RC / (re + RE)",
      "gain_formula_bypassed": "-RC / re",
      "phase_inversion": true,
      "typical_gain_range": { "min": 10, "max": 500 },
      "input_impedance": "R_bias || (beta * (re + RE))",
      "output_impedance": "RC",
      "bandwidth_hint": "medium",
      "internal_components_pattern": ["Q(NPN)", "RC", "RE", "R_bias1", "R_bias2?", "CIN?", "COUT?", "CE?"],
      "constraints": [
        { "name": "vce_active", "rule": "VCE > 0.2V", "severity": "hard" },
        { "name": "bias_stability", "rule": "RE > 0 for stable bias", "severity": "soft" },
        { "name": "power_dissipation", "rule": "P_Q1 < P_max_transistor", "severity": "hard" }
      ],
      "compatible_predecessors": ["cc_block", "ce_block", "non_inverting_block", "inverting_block"],
      "compatible_successors": ["cc_block", "ce_block", "cb_block", "class_a_block", "class_ab_block"],
      "roles": ["amplification"],
      "bias_variants": ["fixed_bias", "voltage_divider", "externally_biased", "collector_feedback"]
    },
    "cb_block": {
      "name": "Common Base Amplifier Block",
      "description": "Tầng khuếch đại BJT mắc base chung. Không đảo pha, Zin thấp, băng thông cao.",
      "device_type": "bjt",
      "input_ports": ["IN_EMITTER"],
      "output_ports": ["OUT_COLLECTOR"],
      "supply_ports": ["VCC", "GND"],
      "bias_ports": ["BIAS_BASE"],
      "gain_formula": "RC / re",
      "phase_inversion": false,
      "typical_gain_range": { "min": 10, "max": 500 },
      "input_impedance": "re",
      "output_impedance": "RC",
      "bandwidth_hint": "high",
      "internal_components_pattern": ["Q(NPN)", "RC", "RE?", "R_bias1", "R_bias2?", "CIN?", "COUT?", "CB?"],
      "constraints": [
        { "name": "vce_active", "rule": "VCE > 0.2V", "severity": "hard" }
      ],
      "compatible_predecessors": ["ce_block", "cs_block"],
      "compatible_successors": ["ce_block", "cc_block"],
      "roles": ["amplification", "current_buffer"],
      "bias_variants": ["voltage_divider", "fixed_bias", "externally_biased"]
    },
    "cc_block": {
      "name": "Common Collector (Emitter Follower) Block",
      "description": "BJT emitter follower. Gain ≈ 1, Zin cao, Zout thấp. Dùng làm buffer.",
      "device_type": "bjt",
      "input_ports": ["IN_BASE"],
      "output_ports": ["OUT_EMITTER"],
      "supply_ports": ["VCC", "GND"],
      "bias_ports": ["BIAS"],
      "gain_formula": "RE / (re + RE)",
      "phase_inversion": false,
      "typical_gain_range": { "min": 0.9, "max": 1.0 },
      "input_impedance": "beta * (re + RE)",
      "output_impedance": "re + R_source/beta",
      "bandwidth_hint": "high",
      "internal_components_pattern": ["Q(NPN)", "RE", "R_bias1", "R_bias2?", "CIN?", "COUT?"],
      "constraints": [
        { "name": "vce_active", "rule": "VCE > 0.2V", "severity": "hard" }
      ],
      "compatible_predecessors": ["ce_block", "cb_block", "non_inverting_block", "differential_block"],
      "compatible_successors": ["ce_block", "load"],
      "roles": ["buffering", "impedance_matching"],
      "bias_variants": ["voltage_divider", "fixed_bias", "externally_biased"]
    },
    "cs_block": {
      "name": "Common Source Amplifier Block",
      "description": "Tầng khuếch đại MOSFET mắc source chung. Đảo pha, gain phụ thuộc gm*RD.",
      "device_type": "mosfet",
      "input_ports": ["IN_GATE"],
      "output_ports": ["OUT_DRAIN"],
      "supply_ports": ["VDD", "GND"],
      "bias_ports": ["BIAS_GATE"],
      "gain_formula": "-gm * RD",
      "gain_formula_unbypassed": "-gm * RD / (1 + gm*RS)",
      "phase_inversion": true,
      "typical_gain_range": { "min": 5, "max": 200 },
      "input_impedance": "R_bias (very high)",
      "output_impedance": "RD",
      "bandwidth_hint": "medium",
      "internal_components_pattern": ["M1(NMOS)", "RD", "RS?", "RG1", "RG2?", "CIN?", "COUT?", "CS?"],
      "constraints": [
        { "name": "vds_saturation", "rule": "VDS > VGS - Vth", "severity": "hard" },
        { "name": "gate_bias", "rule": "VGS > Vth", "severity": "hard" }
      ],
      "compatible_predecessors": ["cd_block", "cs_block", "non_inverting_block"],
      "compatible_successors": ["cd_block", "cs_block", "cg_block"],
      "roles": ["amplification"],
      "bias_variants": ["voltage_divider", "fixed_gate", "externally_biased"]
    },
    "cd_block": {
      "name": "Common Drain (Source Follower) Block",
      "description": "MOSFET source follower. Gain ≈ 1, Zin rất cao, Zout thấp.",
      "device_type": "mosfet",
      "input_ports": ["IN_GATE"],
      "output_ports": ["OUT_SOURCE"],
      "supply_ports": ["VDD", "GND"],
      "bias_ports": ["BIAS_GATE"],
      "gain_formula": "gm*RS / (1 + gm*RS)",
      "phase_inversion": false,
      "typical_gain_range": { "min": 0.8, "max": 1.0 },
      "input_impedance": "very_high (gate)",
      "output_impedance": "1/gm",
      "bandwidth_hint": "high",
      "internal_components_pattern": ["M1(NMOS)", "RS", "RG1", "RG2?", "CIN?", "COUT?"],
      "constraints": [
        { "name": "vds_saturation", "rule": "VDS > VGS - Vth", "severity": "hard" }
      ],
      "compatible_predecessors": ["cs_block", "cg_block"],
      "compatible_successors": ["cs_block", "load"],
      "roles": ["buffering", "impedance_matching"],
      "bias_variants": ["voltage_divider", "fixed_gate", "externally_biased"]
    },
    "cg_block": {
      "name": "Common Gate Amplifier Block",
      "description": "MOSFET common gate. Không đảo pha, Zin thấp, băng thông cao. Phù hợp RF.",
      "device_type": "mosfet",
      "input_ports": ["IN_SOURCE"],
      "output_ports": ["OUT_DRAIN"],
      "supply_ports": ["VDD", "GND"],
      "bias_ports": ["BIAS_GATE"],
      "gain_formula": "gm * RD",
      "phase_inversion": false,
      "typical_gain_range": { "min": 5, "max": 200 },
      "input_impedance": "1/gm",
      "output_impedance": "RD",
      "bandwidth_hint": "very_high",
      "internal_components_pattern": ["M1(NMOS)", "RD", "RS?", "RG1", "RG2?", "CIN?", "COUT?", "CG?"],
      "constraints": [
        { "name": "vds_saturation", "rule": "VDS > VGS - Vth", "severity": "hard" }
      ],
      "compatible_predecessors": ["cs_block"],
      "compatible_successors": ["cd_block", "cs_block"],
      "roles": ["amplification", "current_buffer"],
      "bias_variants": ["voltage_divider", "fixed_gate", "externally_biased"]
    },
    "inverting_block": {
      "name": "Inverting Op-Amp Block",
      "description": "Mạch khuếch đại đảo dùng op-amp. Gain = -RF/RIN.",
      "device_type": "opamp",
      "input_ports": ["IN_SIGNAL"],
      "output_ports": ["OUT"],
      "supply_ports": ["V+", "V-", "GND"],
      "bias_ports": ["VREF?"],
      "gain_formula": "-RF / RIN",
      "phase_inversion": true,
      "typical_gain_range": { "min": 0.1, "max": 1000 },
      "input_impedance": "RIN",
      "output_impedance": "very_low",
      "bandwidth_hint": "depends_on_gbw",
      "internal_components_pattern": ["U(OPAMP)", "RF", "RIN", "VREF?", "CIN?", "COUT?"],
      "constraints": [
        { "name": "output_swing", "rule": "|VOUT| < V_supply - headroom", "severity": "hard" },
        { "name": "gbw_limit", "rule": "gain * bandwidth < GBW_opamp", "severity": "hard" }
      ],
      "compatible_predecessors": ["non_inverting_block", "inverting_block", "differential_block", "ce_block", "cs_block"],
      "compatible_successors": ["non_inverting_block", "inverting_block", "cc_block", "cd_block"],
      "roles": ["amplification"],
      "supply_variants": ["dual_supply", "single_supply_vref"]
    },
    "non_inverting_block": {
      "name": "Non-Inverting Op-Amp Block",
      "description": "Mạch khuếch đại không đảo dùng op-amp. Gain = 1 + RF/RG.",
      "device_type": "opamp",
      "input_ports": ["IN_SIGNAL"],
      "output_ports": ["OUT"],
      "supply_ports": ["V+", "V-", "GND"],
      "bias_ports": ["VREF?"],
      "gain_formula": "1 + RF / RG",
      "phase_inversion": false,
      "typical_gain_range": { "min": 1, "max": 1000 },
      "input_impedance": "very_high",
      "output_impedance": "very_low",
      "bandwidth_hint": "depends_on_gbw",
      "internal_components_pattern": ["U(OPAMP)", "RF", "RG", "VREF?", "CIN?", "COUT?"],
      "constraints": [
        { "name": "output_swing", "rule": "|VOUT| < V_supply - headroom", "severity": "hard" },
        { "name": "gbw_limit", "rule": "gain * bandwidth < GBW_opamp", "severity": "hard" }
      ],
      "compatible_predecessors": ["non_inverting_block", "inverting_block", "differential_block", "ce_block", "cs_block"],
      "compatible_successors": ["non_inverting_block", "inverting_block", "differential_block", "cc_block"],
      "roles": ["amplification", "buffering"],
      "supply_variants": ["dual_supply", "single_supply_vref"]
    },
    "differential_block": {
      "name": "Differential Op-Amp Block",
      "description": "Mạch khuếch đại vi sai dùng op-amp. Gain = R2/R1 (mạch cân xứng).",
      "device_type": "opamp",
      "input_ports": ["IN_POS", "IN_NEG"],
      "output_ports": ["OUT"],
      "supply_ports": ["V+", "V-", "GND"],
      "bias_ports": ["VREF?"],
      "gain_formula": "R2 / R1",
      "phase_inversion": false,
      "typical_gain_range": { "min": 0.1, "max": 1000 },
      "input_impedance": "R1 (each input)",
      "output_impedance": "very_low",
      "bandwidth_hint": "depends_on_gbw",
      "internal_components_pattern": ["U(OPAMP)", "R1", "R2", "R3", "R4", "VREF?", "CIN1?", "CIN2?", "COUT?"],
      "constraints": [
        { "name": "resistor_matching", "rule": "R2/R1 == R4/R3 for CMRR", "severity": "hard" },
        { "name": "output_swing", "rule": "|VOUT| < V_supply - headroom", "severity": "hard" }
      ],
      "compatible_predecessors": ["non_inverting_block"],
      "compatible_successors": ["non_inverting_block", "inverting_block", "cc_block", "cd_block"],
      "roles": ["amplification", "signal_subtraction"],
      "supply_variants": ["dual_supply", "single_supply_vref"]
    },
    "instrumentation_block": {
      "name": "Instrumentation Amplifier Block (3 Op-Amp)",
      "description": "Mạch khuếch đại đo lường 3 op-amp. 2 buffer + 1 differential. Gain rất chính xác, CMRR cao.",
      "device_type": "opamp",
      "input_ports": ["VIN_POS", "VIN_NEG"],
      "output_ports": ["VOUT"],
      "supply_ports": ["V+", "V-", "GND"],
      "bias_ports": ["VREF?"],
      "gain_formula": "(1 + 2*RF/RG) * (R2/R1)",
      "phase_inversion": false,
      "typical_gain_range": { "min": 1, "max": 10000 },
      "input_impedance": "very_high",
      "output_impedance": "very_low",
      "bandwidth_hint": "depends_on_gbw",
      "internal_components_pattern": ["U1(OPAMP)", "U2(OPAMP)", "U3(OPAMP)", "RF1", "RF2", "RG", "R1", "R2", "R3", "R4"],
      "constraints": [
        { "name": "resistor_matching", "rule": "RF1 == RF2, R1/R2 == R3/R4", "severity": "hard" },
        { "name": "cmrr_target", "rule": "CMRR >= 80dB", "severity": "hard" },
        { "name": "output_swing", "rule": "|VOUT| < V_supply - headroom", "severity": "hard" }
      ],
      "compatible_predecessors": [],
      "compatible_successors": ["cc_block", "cd_block", "non_inverting_block"],
      "roles": ["amplification", "measurement", "high_cmrr"],
      "supply_variants": ["dual_supply", "single_supply_vref"]
    },
    "class_a_block": {
      "name": "Class A Power Amplifier Block",
      "description": "Tầng công suất Class A. Điểm Q giữa tải, hoạt động toàn chu kỳ, hiệu suất thấp (~25%).",
      "device_type": "bjt",
      "input_ports": ["IN_BASE"],
      "output_ports": ["OUT_COLLECTOR"],
      "supply_ports": ["VCC", "GND"],
      "bias_ports": ["BIAS"],
      "gain_formula": "-RC / (re + RE)",
      "phase_inversion": true,
      "typical_gain_range": { "min": 5, "max": 100 },
      "input_impedance": "R_bias || (beta * (re + RE))",
      "output_impedance": "RC || RL",
      "bandwidth_hint": "medium",
      "internal_components_pattern": ["Q(NPN)", "RC", "RE", "R1", "R2", "CIN?", "COUT?", "CE?", "RL"],
      "constraints": [
        { "name": "q_point_center", "rule": "VCE ≈ VCC/2", "severity": "soft" },
        { "name": "thermal_limit", "rule": "P_dissipation < P_max", "severity": "hard" }
      ],
      "compatible_predecessors": ["ce_block", "cc_block", "non_inverting_block"],
      "compatible_successors": ["load", "cc_block"],
      "roles": ["power_amplification"],
      "bias_variants": ["voltage_divider", "fixed_bias", "externally_biased"]
    },
    "class_b_block": {
      "name": "Class B Push-Pull Block",
      "description": "Push-pull Class B. Cặp NPN+PNP bổ sung, mỗi transistor dẫn nửa chu kỳ. Có crossover distortion.",
      "device_type": "bjt",
      "input_ports": ["IN_SIGNAL"],
      "output_ports": ["OUT_EMITTER"],
      "supply_ports": ["VCC", "VEE", "GND"],
      "bias_ports": [],
      "gain_formula": "~1 (emitter follower push-pull)",
      "phase_inversion": false,
      "typical_gain_range": { "min": 0.8, "max": 1.0 },
      "input_impedance": "beta * RL (each half)",
      "output_impedance": "re_npn || re_pnp",
      "bandwidth_hint": "high",
      "internal_components_pattern": ["Q1(NPN)", "Q2(PNP)", "Re1?", "Re2?", "CIN?", "COUT?"],
      "constraints": [
        { "name": "crossover", "rule": "crossover_distortion present (no bias)", "severity": "soft" },
        { "name": "symmetry", "rule": "beta_NPN ≈ beta_PNP", "severity": "soft" }
      ],
      "compatible_predecessors": ["ce_block", "inverting_block", "non_inverting_block"],
      "compatible_successors": ["load"],
      "roles": ["power_amplification", "push_pull"],
      "bias_variants": ["no_bias", "externally_biased"]
    },
    "class_ab_block": {
      "name": "Class AB Push-Pull Block",
      "description": "Push-pull Class AB. Thêm bias (diode/resistor) giữa 2 base để giảm crossover distortion.",
      "device_type": "bjt",
      "input_ports": ["IN_SIGNAL"],
      "output_ports": ["OUT_EMITTER"],
      "supply_ports": ["VCC", "VEE", "GND"],
      "bias_ports": ["BIAS_DIODE"],
      "gain_formula": "~1 (push-pull with bias)",
      "phase_inversion": false,
      "typical_gain_range": { "min": 0.85, "max": 1.0 },
      "input_impedance": "beta * RL",
      "output_impedance": "re",
      "bandwidth_hint": "high",
      "internal_components_pattern": ["Q1(NPN)", "Q2(PNP)", "D1?", "D2?", "R_bias?", "Re1?", "Re2?", "CIN?", "COUT?"],
      "constraints": [
        { "name": "bias_voltage", "rule": "V_bias ≈ 2 * VBE (for diode bias)", "severity": "hard" },
        { "name": "thermal_runaway", "rule": "emitter_resistors prevent thermal runaway", "severity": "hard" }
      ],
      "compatible_predecessors": ["ce_block", "inverting_block", "non_inverting_block"],
      "compatible_successors": ["load"],
      "roles": ["power_amplification", "push_pull", "low_distortion"],
      "bias_variants": ["diode_bias", "fixed_bias", "vbe_multiplier", "externally_biased"]
    },
    "class_c_block": {
      "name": "Class C Tuned Amplifier Block",
      "description": "Class C dùng tải cộng hưởng LC. Góc dẫn < 180°, hiệu suất cao (>70%). Dùng cho RF.",
      "device_type": "bjt",
      "input_ports": ["IN_RF"],
      "output_ports": ["OUT_RF"],
      "supply_ports": ["VCC", "GND"],
      "bias_ports": ["BIAS"],
      "gain_formula": "depends on tank Q and coupling",
      "phase_inversion": false,
      "typical_gain_range": { "min": 10, "max": 100 },
      "input_impedance": "varies with bias",
      "output_impedance": "tank impedance at resonance",
      "bandwidth_hint": "narrow (tuned)",
      "internal_components_pattern": ["Q(NPN)", "L_tank", "C_tank", "R_bias?", "RFC?", "CIN?", "COUT?"],
      "constraints": [
        { "name": "resonance", "rule": "f_res = 1/(2*pi*sqrt(L*C))", "severity": "hard" },
        { "name": "conduction_angle", "rule": "theta < 180°", "severity": "hard" }
      ],
      "compatible_predecessors": ["class_c_block"],
      "compatible_successors": ["load_rf", "antenna"],
      "roles": ["rf_amplification", "power_amplification"],
      "bias_variants": ["voltage_divider", "fixed_bias", "externally_biased"]
    },
    "class_d_block": {
      "name": "Class D Switching Amplifier Block",
      "description": "Class D dùng MOSFET switching + PWM + LC filter. Hiệu suất rất cao (>90%).",
      "device_type": "mosfet",
      "input_ports": ["IN_ANALOG", "IN_PWM?"],
      "output_ports": ["OUT_POWER"],
      "supply_ports": ["VDD", "GND"],
      "bias_ports": [],
      "gain_formula": "VDD * duty_cycle (after LC filter)",
      "phase_inversion": false,
      "typical_gain_range": { "min": 1, "max": 50 },
      "input_impedance": "very_high (gate)",
      "output_impedance": "low (with LC filter)",
      "bandwidth_hint": "depends_on_filter",
      "internal_components_pattern": ["M_HIGH(NMOS/PMOS)", "M_LOW(NMOS)?", "L_filter", "C_filter", "COMP?", "DRIVER?"],
      "constraints": [
        { "name": "switching_freq", "rule": "f_sw >> 2 * f_signal_max", "severity": "hard" },
        { "name": "dead_time", "rule": "dead_time prevents shoot-through", "severity": "hard" }
      ],
      "compatible_predecessors": ["comparator", "pwm_generator"],
      "compatible_successors": ["load", "speaker"],
      "roles": ["power_amplification", "high_efficiency"],
      "topology_variants": ["half_bridge", "full_bridge", "comparator_based"]
    },
    "darlington_block": {
      "name": "Darlington Pair Block",
      "description": "Cặp Darlington 2 BJT nối tiếp. Beta tổng = β1 * β2. VBE tổng ≈ 1.4V.",
      "device_type": "bjt",
      "input_ports": ["IN_BASE"],
      "output_ports": ["OUT_COLLECTOR", "OUT_EMITTER"],
      "supply_ports": ["VCC", "GND"],
      "bias_ports": ["BIAS"],
      "gain_formula": "current_gain = beta1 * beta2",
      "voltage_gain_formula": "-RC / (re1 + re2*(1+beta1) + RE)",
      "phase_inversion": true,
      "typical_gain_range": { "min": 1000, "max": 100000, "type": "current" },
      "input_impedance": "very_high (beta1 * beta2 * RE)",
      "output_impedance": "RC",
      "bandwidth_hint": "low (due to Miller effect)",
      "internal_components_pattern": ["Q1(NPN)", "Q2(NPN)", "R_bias1", "R_bias2?", "RC", "RE", "CIN?", "COUT?", "CE?"],
      "constraints": [
        { "name": "vbe_total", "rule": "VBE_total ≈ 1.2V - 1.4V", "severity": "hard" },
        { "name": "thermal", "rule": "P_Q2 < P_max (Q2 carries most current)", "severity": "hard" }
      ],
      "compatible_predecessors": ["ce_block", "non_inverting_block"],
      "compatible_successors": ["load", "cc_block"],
      "roles": ["high_current_gain", "amplification"],
      "bias_variants": ["voltage_divider", "fixed_bias", "externally_biased"]
    },
    "multi_stage_block": {
      "name": "Multi-Stage Amplifier Block",
      "description": "Khối mạch ghép nhiều tầng (CE-CC, CE-CE, CS-CD, ...). Gain tổng = tích gain từng tầng.",
      "device_type": "mixed",
      "input_ports": ["IN"],
      "output_ports": ["OUT"],
      "supply_ports": ["VCC", "GND"],
      "bias_ports": ["BIAS_STAGE1", "BIAS_STAGE2"],
      "gain_formula": "A_total = A_stage1 * A_stage2 * ...",
      "phase_inversion": "depends on stages",
      "typical_gain_range": { "min": 100, "max": 100000 },
      "input_impedance": "Z_in of first stage",
      "output_impedance": "Z_out of last stage",
      "bandwidth_hint": "narrower than single stage",
      "internal_components_pattern": ["stage1_components", "coupling_network", "stage2_components"],
      "constraints": [
        { "name": "loading", "rule": "Z_out_stage_n << Z_in_stage_n+1", "severity": "soft" },
        { "name": "stability", "rule": "phase_margin > 45°", "severity": "hard" }
      ],
      "compatible_predecessors": [],
      "compatible_successors": ["load"],
      "roles": ["high_gain_amplification"],
      "common_configurations": ["CE-CC", "CE-CE", "CS-CD", "CS-CG"]
    },
    "bias_network_block": {
      "name": "Bias Network Block",
      "description": "Mạng phân cực (voltage divider, fixed bias, etc.). Không khuếch đại, chỉ thiết lập Q-point.",
      "device_type": "passive",
      "input_ports": ["VCC"],
      "output_ports": ["VBIAS"],
      "supply_ports": ["VCC", "GND"],
      "bias_ports": [],
      "gain_formula": "N/A (bias only)",
      "phase_inversion": false,
