    "layout_guidelines": [
      {
        "note": "Place Q1 (CE stage) on left and Q2 (CC stage) on right with Cmid coupling between them"
      },
      {
        "note": "Keep Cmid trace between Q1 collector and Q2 base short to minimize noise pickup"
      },
      {
        "note": "Route base bias networks (R1a-R2a, R1b-R2b) away from high-current paths"
      },
      {
        "note": "Star ground CE1, RE1, RE2 for best AC performance"
      },
      {
        "note": "Keep output trace from Q2 emitter short for low output impedance"
      }
    ],
    "thermal_considerations": [
      {
        "note": "Q1 (CE stage) may dissipate more power - ensure adequate spacing"
      },
      {
        "note": "Q2 (CC stage) handles output current - ensure adequate heatsinking if load current > 100mA"
      }
    ],
    "notes": [
      "Two-stage amplifier: CE (high gain) → CC (buffer)",
      "Total gain ≈ gain of CE stage (since CC gain ≈ 1)",
      "CC stage provides low output impedance (<50Ω typical)",
      "Bandwidth narrowed due to cascaded poles",
      "Cmid provides DC isolation between stages",
      "CE1 bypasses RE1 for AC, increasing gain of first stage",
      "Q1 (2N3904) for low-power CE stage, Q2 (2N2222) for higher-current CC buffer",
      "Typical applications: audio pre-amplifiers, sensor signal conditioning"
    ]
  }
