        "library_id": "resources/kicad/symbols/version/Device",
        "symbol_name": "R",
        "footprint": "Resistor_THT:R_Axial_DIN0207_L6.3mm_D2.5mm_P10.16mm_Vertical",
        "symbol_version": "1.0"
      },
      "position": { "x": 10, "y": 10, "group": "collector" }
    },
    {
      "id": "RE",
      "type": "RESISTOR",
      "pins": ["1", "2"],
      "parameters": {
        "resistance": 1000,
        "power_rating": 0.25
