{
  "$schema": "circuit_topology_template.schema.json",
  "topology_type": "bjt_common_emitter_fixed_bias_amplifier",
  "description": "Mạch khuếch đại điện áp BJT mắc emitter chung dùng phân cực cố định (fixed/base bias), có bypass RE cho AC. Sử dụng 3 điện trở (R1, RC, RE) và 3 tụ (CIN, COUT, CE).",
  "category": "bjt",
  "tags": ["common-emitter", "fixed-bias", "emitter-bypass", "ac-amplifier", "3R3C"],

  "components": [
