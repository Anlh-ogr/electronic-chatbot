        "symbol_version": "1.0"
      },
      "position": { "x": 0, "y": 0, "group": "amplifier" }
    },
    {
      "id": "R1",
      "type": "RESISTOR",
      "pins": ["1", "2"],
      "parameters": {
        "resistance": 47000,
        "power_rating": 0.25
      },
      "kicad": {
        "library_id": "resources/kicad/symbols/version/Device",
        "symbol_name": "R",
        "footprint": "Resistor_THT:R_Axial_DIN0207_L6.3mm_D2.5mm_P10.16mm_Vertical",
        "symbol_version": "1.0"
      },
      "position": { "x": -10, "y": 10, "group": "bias" }
    },
    {
      "id": "RC",
      "type": "RESISTOR",
      "pins": ["1", "2"],
      "parameters": {
        "resistance": 4700,
        "power_rating": 0.25
