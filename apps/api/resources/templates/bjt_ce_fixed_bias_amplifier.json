  "nets": [
    {
      "id": "net_vcc",
      "connections": [
        ["VCC", "+"],
        ["RC", "1"],
        ["R1", "1"]
      ]
    },
    {
      "id": "net_collector",
      "connections": [
        ["RC", "2"],
        ["Q1", "C"],
        ["COUT", "1"]
      ]
    },
    {
      "id": "net_base",
      "connections": [
        ["R1", "2"],
        ["Q1", "B"],
        ["CIN", "1"]
      ]
    },
    {
      "id": "net_emitter",
      "connections": [
        ["Q1", "E"],
        ["RE", "1"],
        ["CE", "1"]
      ]
    },
    {
      "id": "net_gnd",
      "connections": [
        ["GND", "GND"],
        ["RE", "2"],
        ["CE", "2"],
        ["VCC", "-"]
      ]
    },
    {
      "id": "net_in",
      "connections": [
        ["VIN", "IN"],
        ["CIN", "2"]
      ]
    },
    {
      "id": "net_out",
      "connections": [
        ["VOUT", "OUT"],
        ["COUT", "2"]
      ]
    }
  ],

  "ports": [
    {
      "id": "VIN",
      "direction": "input",
      "net": "net_in"
    },
    {
      "id": "VOUT",
      "direction": "output",
      "net": "net_out"
    },
    {
      "id": "VCC",
      "direction": "power",
      "net": "net_vcc"
    },
    {
      "id": "GND",
      "direction": "ground",
      "net": "net_gnd"
    }
  ],

  "constraints": [
    {
      "type": "voltage_range",
      "target": "VCC",
      "min": 5.0,
      "max": 24.0
    },
    {
      "type": "current_limit",
      "target": "Q1",
      "max": 0.5
    },
    {
      "type": "power_rating_min",
      "target": "R1",
      "min_watts": 0.25
    },
    {
      "type": "power_rating_min",
      "target": "RC",
      "min_watts": 0.25
    },
    {
      "type": "power_rating_min",
      "target": "RE",
      "min_watts": 0.25
    },
    {
      "type": "voltage_rating_min",
      "target": "CIN",
      "min": 25.0
    },
    {
      "type": "voltage_rating_min",
      "target": "COUT",
      "min": 25.0
    },
    {
      "type": "voltage_rating_min",
      "target": "CE",
      "min": 16.0
    }
  ],

  "parametric": {
    "R1":   { "resistance": "optional" },
    "RC":   { "resistance": "optional" },
    "RE":   { "resistance": "optional" },
    "CIN":  { "capacitance": "optional" },
    "COUT": { "capacitance": "optional" },
    "CE":   { "capacitance": "optional" }
  },

  "pcb_hints": {
    "keepout_zones": [
      { "x": 0, "y": 0, "radius": 5, "reason": "Q1 nhiệt cao" }
    ],
    "critical_nets": ["net_in", "net_out"]
  }
