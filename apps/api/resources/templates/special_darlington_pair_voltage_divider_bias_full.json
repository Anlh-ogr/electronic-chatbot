    "layout_guidelines": [
      {
        "note": "Place Q1 and Q2 close together (within 5-10mm) to minimize parasitic inductance in Darlington connection"
      },
      {
        "note": "Keep E(Q1)→B(Q2) trace short to avoid noise pickup"
      },
      {
        "note": "Route base bias network (R1-R2-CIN) away from output to avoid feedback"
      },
      {
        "note": "Star ground CE, RE at emitter node for best AC performance"
      }
    ],
    "thermal_considerations": [
      {
        "note": "Q2 carries most of the current - ensure adequate spacing or heatsink if IC > 100mA"
      },
      {
        "note": "Darlington has higher VBE (≈1.4V) than single BJT due to stacked VBE drops"
      }
    ],
    "notes": [
      "Darlington configuration: β_total = β₁ × β₂ ≈ 10,000",
      "Very high input impedance (>100kΩ typical)",
      "Used as buffer or high-current driver",
      "Total VBE ≈ 1.4V (two VBE drops in series)",
      "Lower bandwidth than single-stage due to cascaded poles",
      "Q1 is typically low-power (2N3904), Q2 can be higher-power (2N2222)",
